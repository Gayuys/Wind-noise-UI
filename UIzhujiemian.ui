       <item>
        <widget class="QWidget" name="widget_10" native="true">
         <layout class="QVBoxLayout" name="verticalLayout_17">
          <item>
           <widget class="QGroupBox" name="groupBox_2">
            <property name="font">
             <font>
              <pointsize>20</pointsize>
              <bold>true</bold>
             </font>
            </property>
            <property name="styleSheet">
             <string notr="true">QGroupBox {
    /* 核心修改：将边框改为 1像素 黑色 实线 */
    border: 1px solid black;

    /* 推荐保留：设置圆角，保持原本的柔和感（可视情况调整数值） */
    border-radius: 5px;

    /* 关键设置：必须设置顶部边距，给标题文字留出空间 */
    /* 1.5ex 或 2ex 大约对应文字的高度，防止边框压住标题 */
    margin-top: 2ex; 
}

QGroupBox::title {
    /* 重新定义标题的位置，使其位于边框线上方 */
    subcontrol-origin: margin;
    subcontrol-position: top left; /* 标题靠左，如果原图是居中可改为 top center */
    
    /* 细节调整：设置左侧距离和内边距 */
    left: 10px; 
