                     <property name="styleSheet">
                      <string notr="true">/* =================================
   1. 顶部表头 (水平方向) 
   ================================= */
QHeaderView::section:horizontal {
    background-color: #0078D7;  /* 蓝色背景 */
    color: white;               /* 白色文字 */
    border: 1px solid #005a9e;  /* 边框 */
    
    /* ★★★ 核心修改在这里 ★★★ */
    font-size: 14pt;            /* 设置字体大小 (推荐 10pt ~ 12pt) */
    font-family: &quot;Microsoft YaHei&quot;; /* 设置字体为微软雅黑，显示中文更清晰 */
    font-weight: bold;          /* 保持加粗 */
    
    padding-top: 4px;           /* 如果字变大了，可能需要微调内边距 */
    padding-bottom: 4px;
}

/* =================================
   2. 左侧表头 (垂直方向)
   ================================= */
QHeaderView::section:vertical {
    background-color: #F0F0F0;  /* 浅灰背景 */
    color: #333333;             /* 深灰文字 */
    border: 1px solid #DCDCDC;  /* 灰色边框 */
    border-right: 1px solid #999; /* 右边加深一点，区分内容区 */
}

/* =================================
   3. 左上角那个小方块 (交汇处)
   ================================= */
QTableCornerButton::section {
    background-color: #0078D7;  /* 跟顶部保持一致 */
    border: 1px solid #005a9e;
}</string>
