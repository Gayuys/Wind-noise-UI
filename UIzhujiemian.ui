                        <property name="styleSheet">
                         <string notr="true">QLineEdit {
    background: transparent;      /* 背景透明，为了好看 */
    border: none;                 /* 去掉所有边框 */
    border-bottom: 1px solid black; /* 只保留下边框，黑色，1像素 */
    color: black;                 /* 输入文字的颜色 */
    padding-bottom: 2px;          /* 文字和线的距离 */
}

/* 鼠标点进去时的效果（可选，变蓝更明显） */
QLineEdit:focus {
    border-bottom: 2px solid #0078d7; /* 选中时线变粗、变蓝 */
}</string>
