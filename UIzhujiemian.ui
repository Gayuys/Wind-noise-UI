     <property name="layoutDirection">
      <enum>Qt::LayoutDirection::LeftToRight</enum>
     </property>
     <property name="styleSheet">
      <string notr="true">

QTreeWidget {
    /* 1. 设置整体背景色（假设是暗色背景） */
    background-color: #051421; 
    color: #cccccc;
    
    /* 去掉选中时的虚线框 */
    outline: none; 
}

/* 2. 设置每一行的高度（之前教过你的） */
QTreeWidget::item {
    min-height: 40px;
    border: none; /* 去掉边框 */
}

/* 3. 【重点】设置鼠标悬停时的颜色 (浅一点的颜色) */
QTreeWidget::item:hover {
    background-color: #112233;
}

/* 4. 【重点】设置选中时的颜色 (你要的蓝色) */
QTreeWidget::item:selected {
    background-color: #2196F3; /* 这是一个亮蓝色，你可以换成 #0078D7 */
    color: white;              /* 选中后文字变白 */
}

/* 5. 设置失去焦点时的颜色 (防止点击别处后蓝色变灰) */
QTreeWidget::item:selected:!active {
    background-color: #2196F3; /* 保持蓝色 */
    color: white;
}
</string>
